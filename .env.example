# AI
GEMINI_API_KEY=

# 크롤러 (선택)
# SARAMIN_API_KEY=    # 사람인 Open API 키 (https://oapi.saramin.co.kr) — 없으면 사람인 크롤러 스킵

# DB
SUPABASE_URL=
SUPABASE_ANON_KEY=

# 알림
SLACK_WEBHOOK_URL=          # 공고 알림용
SLACK_BOT_TOKEN=            # Slack Bot용 (면접 연습)
SLACK_SIGNING_SECRET=
# EMAIL_FROM=               # 이메일 알림 활성화 시 주석 해제
# SENDGRID_API_KEY=         # 이메일 알림 활성화 시 주석 해제

# 내 프로필 (단순 값)
MY_CAREER_YEARS=3
MY_SKILLS=React,TypeScript,Next.js
MY_PREFERRED_COMPANY_SIZE=스타트업,중견
MY_EXCLUDED_CONDITIONS=게임회사,교대근무,퍼블리셔
MY_MIN_SALARY=5000
MY_JOB_CATEGORY=프론트엔드

# 공고 매칭 기준 점수 (0~100)
MATCH_SCORE_THRESHOLD=70

# 크롤러 1회 실행당 Gemini 호출 한도 (셀프 리밋)
# 일일 무료 할당량의 일부만 사용해 봇 서비스(/interview, /coverletter)용 호출을 보존합니다.
# 계산 예: 일일 한도 1500 × 90% / 하루 2회 실행 = 약 675회/회
# 보수적인 기본값으로 시작하고, 환경에 맞게 조정하세요.
GEMINI_REQUESTS_PER_RUN=50
